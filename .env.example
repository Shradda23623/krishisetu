# -----------------------------------------------------------------------------
# KrishiSetu — Environment Variables Template
# -----------------------------------------------------------------------------
# 1. Copy this file to `.env` (and `.env.development` if needed).
# 2. Replace every placeholder value below with your own credentials.
# 3. NEVER commit `.env` — it is already listed in `.gitignore`.
# -----------------------------------------------------------------------------

# --- Supabase (https://supabase.com) --------------------------------------
# Create a project, then find these in Project Settings → API.
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-public-key"

# --- Stripe (https://stripe.com) ------------------------------------------
# Use a TEST-mode publishable key (starts with `pk_test_`) during development.
# Find it in Stripe Dashboard → Developers → API keys.
VITE_PAYMENTS_CLIENT_TOKEN="pk_test_your_stripe_publishable_key"

# --- Google Maps (optional, for Nearby Farmers) ---------------------------
# The Maps API key is fetched server-side via the `get-maps-key` Supabase
# edge function — set it there as a secret, not in this file.
